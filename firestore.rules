rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 콘솔에서만 최초 관리자 문서 생성. 클라이언트는 본인 문서 읽기만.
    match /adminUsers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // 교수 허가: 이메일(소문자) 키. 관리자만 생성·삭제·수정, 본인 이메일은 읽기.
    match /professorGrantsByEmail/{emailKey} {
      allow read: if request.auth != null && (
        (request.auth.token.email != null && request.auth.token.email.lower() == emailKey) ||
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid))
      );
      allow create, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    match /rooms/{roomId} {
      allow read: if resource.data.status == 'open' || request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.creatorUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.creatorUid == request.auth.uid || isAdmin());
    }

    match /rooms/{roomId}/questions/{qid} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && (
          get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorUid
            == request.auth.uid
          || isAdmin()
        );
    }

    match /rooms/{roomId}/attempts/{attemptId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && attemptId == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}
